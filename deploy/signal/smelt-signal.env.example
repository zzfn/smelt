# 复制到 /etc/smelt/smelt-signal.env 后按需改

# 只本机监听，由 Caddy 反代
SMELT_SIGNAL_BIND=127.0.0.1:7878

# 房间默认存活（秒）
SMELT_ROOM_TTL_SECS=3600

# ICE 里的 STUN 部分：不设则内置公共 STUN（腾讯/小米/Cloudflare/Google），
# 单行 JSON、少空格。想自定义再取消注释：
# SMELT_ICE_SERVERS=[{"urls":"stun:stun.qq.com:3478"},{"urls":"stun:stun.cloudflare.com:3478"}]

# TURN（生产跨网/蜂窝必需）：装 coturn 见 coturn.md / install-coturn.sh，
# 脚本会自动写入这两行。SMELT_TURN_SECRET 必须跟 /etc/turnserver.conf 的
# static-auth-secret= 完全一致——这是 smelt-signal 和 coturn 之间唯一要共享
# 的密钥，从不下发给客户端；smelt-signal 每次 hello_ok 用它现算一个短时效的
# 临时用户名/密码追加进 ICE 列表，比旧版直接写死 TURN username/credential
# 更安全（凭证自动过期），也不会出现两边密码人肉同步、改错了却没有任何报错
# 的静默失败。
# SMELT_TURN_SECRET=
# SMELT_TURN_HOST=signal.example.com:3478
# 临时 TURN 凭证有效期（秒）：不设则跟 SMELT_ROOM_TTL_SECS 一致。别设太短——
# ICE restart（网络抖动后原地重连）不会重新走 hello 拿新凭证，凭证短于会话
# 实际时长会导致 restart 中途 TURN 申请被拒。
# SMELT_TURN_TTL_SECS=3600

RUST_LOG=info
