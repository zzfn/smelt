# 复制到 /etc/smelt/smelt-signal.env 后按需改

# 只本机监听，由 Caddy 反代
SMELT_SIGNAL_BIND=127.0.0.1:7878

# 房间默认存活（秒）
SMELT_ROOM_TTL_SECS=3600

# ICE：不设则进程内默认 Google 公共 STUN（够宽松 NAT 联调）
# systemd EnvironmentFile 对 JSON 引号不友好；有 coturn 时用 drop-in：
#   /etc/systemd/system/smelt-signal.service.d/ice.conf
#   [Service]
#   Environment=SMELT_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]

RUST_LOG=info
