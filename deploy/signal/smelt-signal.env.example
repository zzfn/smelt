# 复制到 /etc/smelt/smelt-signal.env 后按需改

# 只本机监听，由 Caddy 反代
SMELT_SIGNAL_BIND=127.0.0.1:7878

# 房间默认存活（秒）
SMELT_ROOM_TTL_SECS=3600

# ICE：不设则内置公共 STUN（腾讯/小米/Cloudflare/Google）。
# 生产跨网（蜂窝）请装 coturn，见 coturn.md / install-coturn.sh。
# 单行 JSON、少空格；装 coturn 后脚本会自动写入类似：
# SMELT_ICE_SERVERS=[{"urls":"stun:signal.example.com:3478"},{"urls":["turn:signal.example.com:3478?transport=udp","turn:signal.example.com:3478?transport=tcp"],"username":"smelt","credential":"secret"},{"urls":"stun:stun.qq.com:3478"},{"urls":"stun:stun.cloudflare.com:3478"}]

RUST_LOG=info
